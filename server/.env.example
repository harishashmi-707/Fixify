# Server environment variables
NODE_ENV=production
PORT=5000

# MongoDB connection string
MONGO_URI=your_mongo_connection_string

# JWT settings
JWT_SECRET=change_this_secret
JWT_EXPIRE=1h
JWT_REFRESH_EXPIRE=7d

# Upload settings
MAX_FILE_SIZE=5242880

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
