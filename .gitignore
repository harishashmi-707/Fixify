# Fixify - Git Ignore
# Professional MERN stack development workflow

# ─── Environment ───
.env
*.env
.env.*
!.env.example

# ─── Dependencies ───
node_modules/
/client/node_modules/
/server/node_modules/
/server/database_data/
/client/dist/

# ─── Cache & Testing ───
.npm/
.eslintcache
/cache/
*.cache
coverage/

# ─── Uploads (Local fallback) ───
/server/uploads/*
!/server/uploads/.gitkeep

# ─── IDE & Editor ───
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.project
.settings/

# ─── OS Files ───
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ─── Logs ───
*.log
/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Temporary ───
/tmp/
*.tmp
*.bak
*.orig
